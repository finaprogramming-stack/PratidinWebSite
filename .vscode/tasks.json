{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Open Current HTML in Chrome",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\open-html.ps1",
        "-Browser",
        "Chrome",
        "-Path",
        "${file}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      }
    },
    {
      "label": "Open Current HTML in Edge",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\open-html.ps1",
        "-Browser",
        "Edge",
        "-Path",
        "${file}"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      }
    }
  ]
}
